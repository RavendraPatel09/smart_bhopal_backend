# Copy to .env and adjust. All values have safe defaults in app/config.py.

# Database — SQLite by default (zero setup). For Postgres:
# DATABASE_URL=postgresql://user:password@localhost:5432/smart_bhopal
DATABASE_URL=sqlite:///./smart_bhopal.db

# Security — CHANGE THIS in production!
SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (comma separated origins, or * for all)
CORS_ORIGINS=*

# Seeding
SEED_ON_STARTUP=1
SEED_ADMIN_PHONE=9000000000
SEED_ADMIN_PASSWORD=Admin@123

# Uploads
UPLOAD_DIR=uploads

# Rewards
POINTS_ON_SUBMIT=10
POINTS_ON_CLOSED=20
POINTS_WORKER_COMPLETE=15
